# 伺服器與資料庫設定（請複製為 .env）
# DATABASE_URL 預設為 SQLite 檔案路徑；若要改 MySQL，請改成 mysql://...

DATABASE_URL="file:./dev.db"

# JWT 密鑰（本地開發可先用簡單字串，上線請改成足夠強度的隨機值）
JWT_ACCESS_SECRET="dev-access-secret"
JWT_REFRESH_SECRET="dev-refresh-secret"

# 伺服器埠號
PORT=5176

# 前端來源（OAuth callback 用於 postMessage 回前端）
FRONTEND_ORIGIN="http://localhost:5173"

# Google OAuth（到 Google Cloud Console 建立 OAuth Client）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5176/api/auth/google/callback"

# Facebook OAuth（到 Meta for Developers 建立 App）
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:5176/api/auth/facebook/callback"

