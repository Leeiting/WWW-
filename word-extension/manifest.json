{
  "manifest_version": 3,
  "name": "英文單字卡",
  "version": "1.0",
  "description": "框選英文單字，AI 翻譯並儲存為單字卡",
  "permissions": ["storage", "contextMenus", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "activate-selection": {
      "suggested_key": {
        "default": "Alt+Shift+W"
      },
      "description": "啟動英文單字選取模式"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["wordlist/wordlist.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
